LLM_PROVIDER=gemini
# TTS: "polly"（Amazon Polly、要AWS認証情報）または "gemini"。
# 未指定の場合は AWS 認証情報があれば Polly、無ければ Gemini を使う。
TTS_PROVIDER=gemini
STT_PROVIDER=browser

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Amazon Polly 用（IAMユーザーに polly:SynthesizeSpeech 権限が必要）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

SPEECHMATICS_API_KEY=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
